<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#F0F0F0"/>

    <!-- Button surfaces -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#E1E1E1"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#C9DEF5"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="ButtonDisabledBackgroundBrush" Color="#F5F5F5"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#ADADAD"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="ButtonPressedBorderBrush" Color="#005A9E"/>
    <SolidColorBrush x:Key="ButtonDisabledBorderBrush" Color="#CDCDCD"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#ABABAB"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#E0E0E0"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush" Color="#666666"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#717171"/>
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="SelectedForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#007ACC"/>

    <!-- Interactive states -->
    <SolidColorBrush x:Key="RowHoverBackgroundBrush" Color="#E5F3FF"/>
    <SolidColorBrush x:Key="SidebarHoverBackgroundBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="SidebarSelectedBackgroundBrush" Color="#C9DEF5"/>
    <SolidColorBrush x:Key="SidebarSelectedForegroundBrush" Color="#1E1E1E"/>

    <!-- Accent colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="SelectionBarBrush" Color="#E8B4D0"/>

    <!-- Pink logo color works well here -->
    <SolidColorBrush x:Key="CaretBrush" Color="#1E1E1E"/>

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TitleBarButtonForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TitleBarHoverBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="TitleBarPressedBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="CloseForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#E81123"/>
    <SolidColorBrush x:Key="ClosePressedBrush" Color="#C50F1F"/>

</ResourceDictionary>