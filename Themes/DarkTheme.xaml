<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#181818"/>

    <!-- Button surfaces -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#252525"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#333337"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="ButtonDisabledBackgroundBrush" Color="#252525"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#303030"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#303030"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="ButtonPressedBorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="ButtonDisabledBorderBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#404040"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="SelectedForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#FFFFFF"/>

    <!-- Interactive states -->
    <SolidColorBrush x:Key="RowHoverBackgroundBrush" Color="#2A2D2E"/>
    <SolidColorBrush x:Key="SidebarHoverBackgroundBrush" Color="#282828"/>
    <SolidColorBrush x:Key="SidebarSelectedBackgroundBrush" Color="#303030"/>
    <SolidColorBrush x:Key="SidebarSelectedForegroundBrush" Color="#FFFFFF"/>

    <!-- Accent colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="SelectionBarBrush" Color="#F2B705"/>
    <SolidColorBrush x:Key="CaretBrush" Color="#E0E0E0"/>

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#181818"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TitleBarButtonForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TitleBarHoverBrush" Color="#2C2C2C"/>
    <SolidColorBrush x:Key="TitleBarPressedBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="CloseForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#E81123"/>
    <SolidColorBrush x:Key="ClosePressedBrush" Color="#C50F1F"/>

</ResourceDictionary>