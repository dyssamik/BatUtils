<Window x:Class="BatUtils.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Client"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        FocusManager.FocusedElement="{Binding ElementName=CodeTextBox}">

    <Window.Resources>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,8"/>
        </Style>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource AppButton}">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="28"/>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Form -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Code:"        Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CodeTextBox"      Style="{StaticResource FormTextBox}"/>

            <TextBlock Grid.Row="1" Text="Name:"        Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="NameTextBox"      Style="{StaticResource FormTextBox}"/>

            <TextBlock Grid.Row="2" Text="RK7 Address:" Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="RKAddressTextBox" Style="{StaticResource FormTextBox}"/>

            <TextBlock Grid.Row="3" Text="RK7 Port:"    Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="RKPortTextBox"    Style="{StaticResource FormTextBox}"/>

            <TextBlock Grid.Row="4" Text="SH5 Address:" Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="SHAddressTextBox" Style="{StaticResource FormTextBox}"/>

            <TextBlock Grid.Row="5" Text="SH5 Port:"    Style="{StaticResource FormLabel}" Margin="0,0,10,0"/>
            <TextBox   Grid.Row="5" Grid.Column="1" x:Name="SHPortTextBox"    Style="{StaticResource FormTextBox}" Margin="0"/>
        </Grid>

        <!-- Buttons: Enter = OK, Esc = Cancel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK"     Style="{StaticResource DialogButton}" IsDefault="True" Margin="0,0,8,0" Click="OkButton_Click"/>
            <Button Content="Cancel" Style="{StaticResource DialogButton}" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>