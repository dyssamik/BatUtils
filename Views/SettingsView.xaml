<UserControl x:Class="BatUtils.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:properties="clr-namespace:BatUtils.Properties">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="24">

            <!-- Page title -->

            <TextBlock Text="{x:Static properties:Strings.SettingsTitle}"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForegroundBrush}"
                       Margin="0,0,0,20"/>

            <!-- Appearance -->

            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18"
                    Margin="0,0,0,16">

                <StackPanel>

                    <TextBlock Text="{x:Static properties:Strings.SettingsAppearance}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"
                               Margin="0,0,0,14"/>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Static properties:Strings.SettingsTheme}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"/>

                        <ComboBox x:Name="ThemeComboBox"
                                  Grid.Column="1"
                                  Width="140"
                                  HorizontalAlignment="Left"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">

                            <ComboBoxItem Tag="Dark"
                                          Content="{x:Static properties:Strings.SettingsThemeDark}"/>

                            <ComboBoxItem Tag="Light"
                                          Content="{x:Static properties:Strings.SettingsThemeLight}"/>

                        </ComboBox>

                    </Grid>

                </StackPanel>

            </Border>

            <!-- Language -->

            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">

                <StackPanel>

                    <TextBlock Text="{x:Static properties:Strings.SettingsLanguage}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"
                               Margin="0,0,0,14"/>

                    <StackPanel Margin="8,0,0,0">

                        <RadioButton x:Name="EnglishRadio"
                                     GroupName="Language"
                                     Margin="0,0,0,8"
                                     Checked="EnglishRadio_Checked">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock FontSize="18"
                                           Text="🇺🇸"
                                           Margin="0,0,8,0"/>

                                <TextBlock Text="{x:Static properties:Strings.SettingsLanguageEnglish}"/>

                            </StackPanel>

                        </RadioButton>

                        <RadioButton x:Name="RussianRadio"
                                     GroupName="Language"
                                     Checked="RussianRadio_Checked">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock FontSize="18"
                                           Text="🇷🇺"
                                           Margin="0,0,8,0"/>

                                <TextBlock Text="{x:Static properties:Strings.SettingsLanguageRussian}"/>

                            </StackPanel>

                        </RadioButton>

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>