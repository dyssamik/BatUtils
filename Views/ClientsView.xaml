<UserControl x:Class="BatUtils.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Toolbar Button Style -->
        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource AppButton}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButton" BasedOn="{StaticResource ToolbarButton}" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <!-- DataGrid Row Style -->
        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Cell Style -->
        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="BorderBrush" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Centered Cell Content Style -->
        <Style x:Key="CenteredCellText"
                 TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid Column Header Style -->
        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- TextBlock Styles -->
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,0,8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddButton"
                        Style="{StaticResource ToolbarButton}"
                        Content="+ Add"
                        Click="AddButton_Click"/>

                <Button x:Name="EditButton"
                        Style="{StaticResource ToolbarButton}"
                        Content="✎ Edit"
                        Click="EditButton_Click"/>

                <Button x:Name="DeleteButton"
                        Style="{StaticResource ToolbarButton}"
                        Content="✕ Delete"
                        Click="DeleteButton_Click"/>
            </StackPanel>

            <Button x:Name="RefreshButton"
                    Grid.Column="2"
                    Style="{StaticResource ToolbarButton}"
                    Content="⟳ Refresh"
                    Click="RefreshButton_Click"/>
        </Grid>

        <!-- Clients Grid -->
        <DataGrid x:Name="ClientsGrid"
                  Grid.Row="2"
                  Background="#1E1E1E"
                  Foreground="#CCCCCC"
                  BorderBrush="#303030"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="None"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code"
                                    Binding="{Binding Code}"
                                    ElementStyle="{StaticResource CenteredCellText}"/>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    ElementStyle="{StaticResource CenteredCellText}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Client Info Panel -->
        <Border Grid.Row="4"
                Background="#2D2D30"
                BorderBrush="#303030"
                BorderThickness="1"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Client Info" Style="{StaticResource SectionHeader}" FontSize="15"/>

                <!-- Three columns: General / RK7 / SH5 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- General -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="General" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Code:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding SelectedItem.Code, ElementName=ClientsGrid, TargetNullValue='—', FallbackValue='—'}" 
                                       Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding SelectedItem.Name, ElementName=ClientsGrid, TargetNullValue='No client selected', FallbackValue='No client selected'}" 
                                       Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Grid.Column="1" Width="1" Background="#404040" Margin="0,4"/>

                    <!-- RK7 -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="RK7" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Addr &amp; Port:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding SelectedItem.RKeeperAddress, ElementName=ClientsGrid, TargetNullValue='—', FallbackValue='—'}" 
                                       Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding SelectedItem.RKeeperStatus, ElementName=ClientsGrid, TargetNullValue='—', FallbackValue='—'}" 
                                       Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Grid.Column="3" Width="1" Background="#404040" Margin="0,4"/>

                    <!-- SH5 -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="SH5" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Addr &amp; Port:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding SelectedItem.StoreHouseAddress, ElementName=ClientsGrid, TargetNullValue='—', FallbackValue='—'}" 
                                       Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding SelectedItem.StoreHouseStatus, ElementName=ClientsGrid, TargetNullValue='—', FallbackValue='—'}" 
                                       Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Style="{StaticResource ActionButton}" Content="Check" Click="CheckButton_Click"/>
                    <Button Style="{StaticResource ActionButton}" Content="Open" Click="OpenButton_Click"/>
                    <Button Style="{StaticResource ActionButton}" Content="Explore" Click="ExploreButton_Click"/>
                    <Button Style="{StaticResource ActionButton}" Width="40" Content="..." Click="MoreButton_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>