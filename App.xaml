<Application x:Class="BatUtils.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme -->
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Your AppButton style stays here. 
                 It uses DynamicResource internally, so it will update automatically! -->
            <Style x:Key="AppButton" TargetType="Button">
                <!-- ... (keep your existing AppButton style exactly as it was) ... -->
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>