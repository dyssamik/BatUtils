<UserControl x:Class="BatUtils.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BatUtils.Controls">

    <Border Background="#1A1A1A">

        <StackPanel Margin="0,12">

            <controls:SidebarItem
                x:Name="ClientsItem"
                Text="Clients"
                Page="Clients"
                IsSelected="True"/>

            <controls:SidebarItem
                x:Name="ToolsItem"
                Text="Tools"
                Page="Tools"/>

            <controls:SidebarItem
                x:Name="SettingsItem"
                Text="Settings"
                Page="Settings"/>

            <controls:SidebarItem
                x:Name="InfoItem"
                Text="Info"
                Page="Info"/>

        </StackPanel>

    </Border>

</UserControl>