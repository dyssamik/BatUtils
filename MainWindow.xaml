<Window x:Class="BatUtils.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:BatUtils.Controls"
        Title="BAT Utils"
        Width="850"
        Height="550"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
        CaptionHeight="32"
        ResizeBorderThickness="8"
        CornerRadius="0"
        GlassFrameThickness="0,0,0,1"
        UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->

        <controls:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            MinimizeClicked="TitleBar_MinimizeClicked"
            MaximizeClicked="TitleBar_MaximizeClicked"
            CloseClicked="TitleBar_CloseClicked"/>

        <!-- Main area -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:Sidebar
                x:Name="Sidebar"
                Grid.Column="0"/>

            <ContentControl
                x:Name="MainContent"
                Grid.Column="1"/>

        </Grid>

        <!-- Status bar -->

        <Border Grid.Row="2"
                Background="#181818">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Margin="10,0"
                           VerticalAlignment="Center">

                    <Hyperlink
                        Foreground="#808080"
                        TextDecorations="{x:Null}"
                        Cursor="Hand"
                        Click="GitHubLink_Click">
                        GitHub Project
                    </Hyperlink>

                </TextBlock>

                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#808080"
                    Text="v0.1a"/>

            </Grid>

        </Border>

    </Grid>

</Window>