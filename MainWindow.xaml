<Window x:Class="BatUtils.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BatUtils.Controls"
        Title="BAT Utils"
        Width="850"
        Height="550"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->

        <controls:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            MinimizeClicked="TitleBar_MinimizeClicked"
            MaximizeClicked="TitleBar_MaximizeClicked"
            CloseClicked="TitleBar_CloseClicked"
            DragRequested="TitleBar_DragRequested"/>

        <!-- Main area -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:Sidebar Grid.Column="0"/>

            <ContentControl
                x:Name="MainContent"
                Grid.Column="1"/>

        </Grid>

        <!-- Status bar -->

        <Border Grid.Row="2"
                Background="#181818">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Foreground="#808080"
                    Text="github.com"/>

                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#808080"
                    Text="v0.1a"/>

            </Grid>

        </Border>

    </Grid>

</Window>